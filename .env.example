# ─── Server ───────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────
MONGO_URI=mongodb://localhost:27017/blogweb

# ─── JWT Secrets ──────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# ─── Client URL (CORS) ───────────────────
CLIENT_URL=http://localhost:5173
